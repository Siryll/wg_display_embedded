  "type": "commonjs",
  "main": "index.html",
  "scripts": {
    "serve": "concurrently 'npm run tailwind' 'npm run trunk'",
    "trunk": "trunk serve",
    "tailwind": "npm exec @tailwindcss/cli -- -i ./input.css -o ./output.css --watch",
    "tailwind-build": "npm exec @tailwindcss/cli -- -i ./input.css -o ./output.css --minify"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "node": "^25.9.0"
  }
}
